// EasyMom Foods — Prisma schema
// SQLite for local dev. Turso for production.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  tagline     String
  description String
  count       Int       @default(1)
  accent      String
  hue         Int
  sortOrder   Int       @default(0)
  products    Product[]

  @@index([sortOrder])
}

model Product {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])
  price        Int
  mrp          Int
  weight       String
  rating       Float    @default(0)
  reviewCount  Int      @default(0)
  badge        String?
  bestSeller   Boolean  @default(false)
  isNew        Boolean  @default(false)
  img          String?
  images       String   @default("[]") // JSON array of image paths
  shortDesc    String
  description  String
  ingredients  String   @default("[]") // JSON array
  origin       String
  shelfLife    String
  spiceLevel   String
  cookingTime  String
  servings     String
  tags         String   @default("[]") // JSON array
  hue          Int
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  reviews      Review[]

  @@index([categoryId])
  @@index([active])
  @@index([bestSeller])
  @@index([createdAt])
}

model Recipe {
  id          String    @id @default(cuid())
  title       String
  region      String
  time        String
  serves      String
  difficulty  String
  productSlug String
  excerpt     String
  steps       String    @default("[]") // JSON array
  hue         Int
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  location  String
  role      String
  quote     String
  rating    Int
  product   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model Order {
  id            String   @id @default(cuid())
  orderId       String   @unique
  email         String
  name          String
  phone         String
  address       String
  city          String
  state         String
  pincode       String
  notes         String?
  subtotal      Int
  discount      Int      @default(0)
  shipping      Int      @default(0)
  total         Int
  couponCode    String?
  paymentMethod String   @default("cod") // cod | upi_qr
  paymentRef    String?
  paymentStatus String   @default("pending") // pending | paid
  status        String   @default("confirmed") // confirmed | packed | shipped | delivered | cancelled
  itemsJson     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@index([paymentStatus])
}

model Coupon {
  code        String   @id
  discountPct Int
  active      Boolean  @default(true)
  usageLimit  Int?
}

model NewsletterSub {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model SiteContent {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  name      String
  email     String?
  rating    Int
  title     String
  body      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([active])
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([sortOrder])
}
