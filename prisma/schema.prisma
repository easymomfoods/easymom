// EasyMom Foods — Prisma schema
// SQLite for local dev. The storefront reads from a typed catalog in
// src/lib/data.ts; orders placed via guest checkout are persisted here.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Order {
  id           String   @id @default(cuid())
  orderId      String   @unique // human-friendly e.g. EM-XXXXXX
  email        String
  name         String
  phone        String
  address      String
  city         String
  state        String
  pincode      String
  notes        String?
  subtotal     Int
  discount     Int      @default(0)
  shipping     Int      @default(0)
  total        Int
  couponCode   String?
  paymentRef   String?
  status       String   @default("confirmed") // confirmed | packed | shipped | delivered
  itemsJson    String // JSON string of cart lines
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Coupon {
  code        String   @id
  discountPct Int
  active       Boolean  @default(true)
}

model NewsletterSub {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
